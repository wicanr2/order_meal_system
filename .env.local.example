# ───────── 本機開發 (M2~M5) ─────────
# 值來自 `supabase status` 的輸出 (本機自簽,非雲端申請)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status 的 anon key>

# 後端 / Server Action 用 (繞過 RLS,僅 server 端,切勿放進前端 bundle)
SUPABASE_SERVICE_ROLE_KEY=<supabase status 的 service_role key>

# ───────── 雲端 (M6~M7,切回對外網路再填) ─────────
